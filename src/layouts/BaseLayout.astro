---
import '@/styles/globals.css';
import Head from '@/components/Head.astro';
import PageFooter from '@/components/layouts/ui/page-footer';
import PageHeader from '@/components/layouts/ui/page-header';
import type { PageMetadata } from '@/lib/types/PageMetadata';

interface Props {
  meta?: PageMetadata;
}

const { meta } = Astro.props;
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <Head meta={meta} />
  </head>
  <body>
    <div
      class="flex min-h-screen flex-col items-center justify-between p-4 font-body"
      style="--font-logo: 'Noto Serif Variable', serif; --font-heading: 'Noto Serif Variable', serif; --font-body: 'Noto Serif Variable', serif; --font-sans: 'Noto Sans Variable', sans-serif; --font-mono: 'Fira Mono', monospace;"
    >
      <div class="flex flex-col items-center w-full">
        <PageHeader client:load transition:persist />
        <slot />
      </div>
      <PageFooter client:load transition:persist />
    </div>
  </body>
</html>
