---
import { getCollection } from 'astro:content';
import PostList from '@/components/posts/post-list';
import { TitleText } from '@/components/typography/title-text';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { PostMetadata } from '@/lib/types/PostMetadata';
import { toPostTopic } from '@/lib/types/PostTopic';

const allPosts = await getCollection('posts');

const posts: PostMetadata[] = allPosts
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    keywords: post.data.keywords,
    postnum: String(post.data.postnum),
    slug: post.id,
    url: `https://parkerlandon.com/posts/${post.id}`,
    topics: post.data.keywords?.split(', ').map(toPostTopic) ?? [],
  }))
  .sort((a, b) => +b.postnum - +a.postnum);

const meta = {
  title: "Parker's Posts",
  description: "Parker's blog posts about software engineering.",
  url: 'https://parkerlandon.com/posts',
};
---

<BaseLayout meta={meta}>
  <main>
    <TitleText>Parker&apos;s Posts</TitleText>
    <PostList posts={posts} client:load />
  </main>
</BaseLayout>
